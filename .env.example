# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# On Windows (PowerShell):
#   Copy-Item .env.example .env
#
# Get your Supabase values from: Project Settings → API
# Get your Stripe publishable key from: Stripe Dashboard → Developers → API keys
# Create a one-time $29 price in Stripe and use its Price ID below
# Set VITE_APP_URL to your local dev URL or production domain

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_APP_URL=http://localhost:5173

# Server-side only (do not prefix with VITE_)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
